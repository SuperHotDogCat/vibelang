fn main() -> int {
    var a: int;
    a = 1;
    if (a != 1) { return 1; }

    var b: int = 2;
    if (b != 2) { return 2; }

    var c: float = 3.0;
    if (c != 3.0) { return 3; }

    var d: bool = true;
    if (!d) { return 4; }

    var e: string = "hello";
    // Simplified comparison since we don't have strcmp easily without extern
    if (e == "") { return 5; }

    return 0;
}
