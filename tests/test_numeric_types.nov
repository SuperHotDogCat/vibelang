extern fn printf(fmt: string, ...) -> int;

fn main() -> int {
    var i16: int16 = 10;
    var i32: int32 = 20;
    var i64: int64 = 30;

    // Test promotion
    var sum: int64 = i16 + i32 + i64;
    if (sum != 60) { return 1; }

    var f32: float32 = 1.5;
    var f64: float64 = 2.5;

    // Test float promotion
    var fsum: float64 = f32 + f64;
    if (fsum != 4.0) { return 2; }

    // Test int to float promotion
    var mixed: float64 = i64 + f64;
    if (mixed != 32.5) { return 3; }

    return 0;
}
