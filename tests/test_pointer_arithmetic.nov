import "std.nov";

fn main() -> int {
    var p: int*;
    var raw: void*;
    raw = malloc(16);
    p = raw as int*;

    var x: int = 42;
    p[0] = x;

    var val: int;
    val = *p;
    if (val != 42) { return 1; }

    var p3: int*;
    p3 = raw as int*;
    var val3: int;
    val3 = p3[0];
    if (val3 != 42) { return 3; }

    free(raw);
    return 0;
}
