import "std.nov";

fn main() -> int {
    var s: Stack;
    s.init(10);
    s.push(1);
    s.push(2);
    s.push(3);

    if (s.pop() == 3) {
        if (s.peek() == 2) {
            if (s.is_empty() == false) {
                printf("Stack test passed\n");
                return 0;
            }
        }
    }
    return 1;
}
