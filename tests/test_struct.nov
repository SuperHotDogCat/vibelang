struct Point {
    x: int;
    y: int;
}

impl Point {
    fn set(x: int, y: int) -> void {
        self.x = x;
        self.y = y;
    }

    fn area() -> int {
        return self.x * self.y;
    }
}

fn main() -> int {
    var p: Point;
    p.set(10, 20);
    if (p.area() == 200) {
        return 0;
    }
    return 1;
}
